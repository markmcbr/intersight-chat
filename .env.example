# Ollama OpenAI-compatible endpoint
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Ollama tags endpoint (used to discover available models)
OLLAMA_TAGS_URL=http://localhost:11434/api/tags

# Intersight API base URL (override only for non-SaaS / appliance deployments)
INTERSIGHT_BASE_URL=https://intersight.com

# Path to the built MCP server entry point. Leave default unless you move things.
MCP_SERVER_CMD=node
MCP_SERVER_ARGS=mcp-server/dist/index.js

# Host port that the bundled Ollama container publishes to. Change this if
# port 11434 is already taken on the host (e.g. Ollama running natively).
# Compose-only setting — ignored by the local-Python run path.
OLLAMA_HOST_PORT=11434

# --- LLM runtime tuning (all optional; defaults shown) -------------------
#
# KV-cache size, enforced on the ollama container (compose maps this
# value to OLLAMA_CONTEXT_LENGTH). MUST be set server-side: Ollama's
# OpenAI-compatible /v1/chat/completions endpoint silently drops the
# per-request options.num_ctx field (see ollama/ollama#6286, #6544).
# Big models advertise 256K+ max contexts and the runtime allocates
# KV memory for the WHOLE window upfront — for a 120B MoE that's tens
# of GB and forces CPU offload on a single 48 GB GPU, dropping
# throughput from ~25 to ~6 tok/s. 8192 covers every prompt in this
# app comfortably; raise only for very long reference documents.
LLM_NUM_CTX=8192
#
# Reasoning-mode toggle for models with a "thinking" capability
# (nemotron-3-super, gpt-oss, etc.). Default is true because some
# reasoning models on Ollama 0.30 (notably nemotron-3-super:120b)
# return an EMPTY response when think=false is sent via the OpenAI-
# compat endpoint — Ollama eats both the thinking block and the
# answer. Leaving it on costs a few seconds of latency for a short
# internal reasoning trace but guarantees the model actually replies.
# Other (non-thinking) models silently ignore this setting.
LLM_THINKING=true
#
# How many parallel inference slots Ollama reserves per loaded model.
# Default in Ollama is 4; this app only ever issues one request at a
# time, so 1 frees ~75% of the per-model KV reservation for cache.
OLLAMA_NUM_PARALLEL=1
#
# Max number of models the Ollama container keeps in VRAM at once. On
# a single 48 GB GPU, holding multiple big models is what triggers the
# llama-server segfaults during sidebar model swaps. 1 = swap on demand.
OLLAMA_MAX_LOADED_MODELS=1
